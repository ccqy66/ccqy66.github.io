k","*list.list","*treenod","*treenode)","0","0)",":=","=","==",">","aftertraversal(nod","aftertraversal(node.left)","aftertraversal(node.right)","append(result,","args)","bool{","e","e.(*treenode)","empty()","fals","fmt.print(node.val)","fmt.println(result)","func","golang底层实现","int","interface{}){","interface{}{","introduct","left","len()","main(string[]","make([]int,","middletraversal(nod","middletraversal(node.left)","middletraversal(node.right)","newstack()","nil","nil{","node","pop()","pretraversal(nod","pretraversal(node.left)","pretraversal(node.right)","pretraversalnorecursion(nod","public","push(el","result","return","right","stack","stack)","stack.pop()","stack.push(node)","stack.push(v.left)","stack.push(v.right)","stack.stack.back()","stack.stack.len()","stack.stack.pushback(element)","stack.stack.remove(e)","stack{","stack{stack:list.new()}","static","struct","treenod","true","type","v","v.left","v.right","v.val)","val","void","{","}","中序遍历：","二叉树节点定义","二叉树遍历","分布式系统设计","前序遍历：","后序遍历","操作系统与网络","数据结构与算法","数组","栈定义","树","系统设计","系统设计与实现","递归写法","非递归写法"],"pipeline":["stopWordFilter","stemmer"]},"store":{"./":{"url":"./","title":"Introduction","keywords":"","body":""},"algorithm/":{"url":"algorithm/","title":"数据结构与算法","keywords":"","body":"二叉树节点定义\ntype TreeNode struct {\n    Val   int\n    Left  *TreeNode\n    Right *TreeNode\n}\n\n栈定义\ntype Stack struct {\n    stack *list.List\n}\n\nfunc NewStack() Stack{\n    return Stack{stack:list.New()}\n}\n\nfunc (stack Stack) Push(element interface{}){\n    stack.stack.PushBack(element)\n}\n\nfunc (stack Stack) Pop() interface{}{\n    e := stack.stack.Back()\n    if e == nil {\n        return nil\n    }\n    stack.stack.Remove(e)\n    return e\n}\n\nfunc (stack Stack) Len() int {\n    return stack.stack.Len()\n}\n\nfunc (stack Stack) Empty() bool{\n    if stack.stack.Len() > 0 {\n        return false\n    }\n    return true\n}\n\n"},"algorithm/树/":{"url":"algorithm/树/","title":"树","keywords":"","body":"树\n"},"algorithm/树/二叉树遍历/Traverse.html":{"url":"algorithm/树/二叉树遍历/Traverse.html","title":"二叉树遍历","keywords":"","body":"前序遍历：\n递归写法\nfunc PreTraversal(node *TreeNode) {\n    if node == nil {\n        return\n    }\n    fmt.Print(node.Val)\n    PreTraversal(node.Left)\n    PreTraversal(node.Right)\n}\n\n非递归写法\nfunc PreTraversalNoRecursion(node *TreeNode) {\n    if node == nil {\n        return\n    }\n    stack := NewStack()\n    result := make([]int, 0)\n    stack.Push(node)\n    for !stack.Empty() {\n        e := stack.Pop()\n        v := e.(*TreeNode)\n        result = append(result, v.Val)\n        if v.Right != nil{\n            stack.Push(v.Right)\n        }\n        if v.Left != nil{\n            stack.Push(v.Left)\n        }\n    }\n    fmt.Println(result)\n}\n\n中序遍历：\nfunc MiddleTraversal(node *TreeNode) {\n    if node == nil {\n        return\n    }\n    MiddleTraversal(node.Left)\n    fmt.Print(node.Val)\n    MiddleTraversal(node.Right)\n}\n\n后序遍历\nfunc AfterTraversal(node *TreeNode) {\n    if node == nil {\n        return\n    }\n    AfterTraversal(node.Left)\n    AfterTraversal(node.Right)\n    fmt.Print(node.Val)\n}\n\n"},"algorithm/数组/":{"url":"algorithm/数组/","title":"数组","keywords":"","body":""},"os_network/":{"url":"os_network/","title":"操作系统与网络","keywords":"","body":"public static void main(String[] args) {\n}\n\n"},"system_design/":{"url":"system_design/","title":"系统设计与实现","keywords":"","body":"系统设计\n"},"golang/":{"url":"golang/","title":"Golang底层实现","keywords":"","body":""},"distributed/":{"url":"distributed/","title":"分布式系统设计","keywords":"","body":""}}}