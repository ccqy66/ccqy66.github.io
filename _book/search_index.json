esult = append(result, v.Val)\n        if v.Right != nil{\n            stack.Push(v.Right)\n        }\n        if v.Left != nil{\n            stack.Push(v.Left)\n        }\n    }\n    fmt.Println(result)\n}\n\n中序遍历：\nfunc MiddleTraversal(node *TreeNode) {\n    if node == nil {\n        return\n    }\n    MiddleTraversal(node.Left)\n    fmt.Print(node.Val)\n    MiddleTraversal(node.Right)\n}\n\n后序遍历\nfunc AfterTraversal(node *TreeNode) {\n    if node == nil {\n        return\n    }\n    AfterTraversal(node.Left)\n    AfterTraversal(node.Right)\n    fmt.Print(node.Val)\n}\n\n"},"algorithm/树/404.左叶子之和.html":{"url":"algorithm/树/404.左叶子之和.html","title":"404.左叶子节点之和","keywords":"","body":"题目描述\n计算给定二叉树的所有左叶子之和。\n示例\n    3\n   / \\\n  9  20\n    /  \\\n   15   7\n\n在这个二叉树中，有两个左叶子，分别是 9 和 15，所以返回 24\n说明\n\n无\n分析\n本题有两个关键点：\n\n判断当前节点为左叶子节点。\n写出递归过程。如何判断一个节点为左叶子节点？\n对于示例中的二叉树而言，要判断9是否为左叶子节点，只能从9的父节点3上下功夫，当遍历到9\n时，已经失去了该节点是左节点还是右节点的信息。所以一定要从父节点来判断。func isLeftLeaves(root *TreeNode) bool{\n  if root == nil {\n      return false\n  }\n  if root.Left != nil && root.Left.Left == nil && root.Left.Right == nil {\n      return true\n  }  \n  return false\n}\n\n如何定义递归过程？\n对于任意一个节点，需要进行如下操作：\n判断当前节点的左节点是否为叶子节点，如果是，把当前节点的左节点的值加上，并递归处理右节点。\n如果左节点不是叶子节点，那么就分别递归处理左节点和右节点。\n\n\n解答\nfunc sumOfLeftLeaves(root *TreeNode) int {\n    if root == nil {\n        return 0\n    }\n    if root.Left != nil && root.Left.Left == nil && root.Left.Right == nil {\n        return root.Left.Val + sumOfLeftLeaves(root.Right)\n    }\n    return sumOfLeftLeaves(root.Left) + sumOfLeftLeaves(root.Right)\n}\n\n"},"algorithm/数组/":{"url":"algorithm/数组/","title":"数组","keywords":"","body":""},"algorithm/数组/283.移动零.html":{"url":"algorithm/数组/283.移动零.html","title":"283.移动零","keywords":"","body":"题目描述\n给定一个数组 nums，编写一个函数将所有 0 移动到数组的末尾，同时保持非零元素的相对顺序。\n示例\n输入: [0,1,0,3,12]\n输出: [1,3,12,0,0]\n说明\n\n必须在原数组上操作，不能拷贝额外的数组。\n尽量减少操作次数。\n\n分析\n解答\nfunc moveZeroes(nums []int)  {\n\n}\n\n"},"os_network/":{"url":"os_network/","title":"操作系统与网络","keywords":"","body":""},"os_network/network/":{"url":"os_network/network/","title":"计算机网络","keywords":"","body":""},"os_network/network/tcp_connect.html":{"url":"os_network/network/tcp_connect.html","title":"TCP","keywords":"","body":"连接建立\n由于 TCP 要提供可靠的通信机制，在传输数据之前，必须先初始化一条客户端（请求端）到服务器（被请求端）的 TCP 连接，在连接正式建立后，双方经 TCP 连接通道进行数据传输。\n三次握手\n为了建立一条可靠的通信信道，客户端和服务端通过三次握手的方式来初始化连接。\n初始状态\n连接创建前\n\n"},"system_design/":{"url":"system_design/","title":"系统设计与实现","keywords":"","body":"系统设计\n"},"golang/":{"url":"golang/","title":"Golang底层实现","keywords":"","body":""},"distributed/":{"url":"distributed/","title":"分布式系统设计","keywords":"","body":""}}}